<div style="display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;">Use this secure link to choose a new password for your Nexa CRM account.</div>
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="width:100%;background-color:#f3f6f8;">
        <tr>
            <td align="center" style="padding:36px 16px;">
                <table role="presentation" width="600" cellspacing="0" cellpadding="0" border="0" style="width:100%;max-width:600px;background-color:#ffffff;border:1px solid #dce5e8;border-radius:8px;overflow:hidden;">
                    <tr>
                        <td style="padding:24px 32px;background-color:#12343b;border-bottom:4px solid #20a39e;">
                            <span style="display:inline-block;color:#ffffff;font-size:22px;font-weight:700;line-height:28px;">Nexa <span style="color:#70ddd5;">CRM</span></span>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:40px 32px 20px;">
                            <p style="margin:0 0 12px;color:#147d79;font-size:13px;font-weight:700;line-height:18px;text-transform:uppercase;letter-spacing:0;">Secure account recovery</p>
                            <h1 style="margin:0 0 16px;color:#17252b;font-size:28px;font-weight:700;line-height:36px;letter-spacing:0;">Reset your password</h1>
                            <p style="margin:0;color:#52656d;font-size:16px;line-height:25px;">We received a request to reset the password for your Nexa CRM account. Use the button below to choose a new password.</p>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:12px 32px 28px;">
                            <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                                <tr>
                                    <td align="center" bgcolor="#147d79" style="border-radius:6px;">
                                        <a href="{{link}}" style="display:inline-block;padding:14px 24px;color:#ffffff;text-decoration:none;font-size:16px;font-weight:700;line-height:20px;">Reset password</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:0 32px 28px;">
                            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="width:100%;background-color:#eef7f6;border-left:4px solid #20a39e;">
                                <tr>
                                    <td style="padding:16px;color:#34525a;font-size:14px;line-height:22px;">
                                        <strong style="color:#17252b;">For your security:</strong> this link expires in <strong>{{expiresIn}}</strong> and can only be used once. Nexa will never ask you to share your password or this reset link.
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:0 32px 36px;">
                            <p style="margin:0 0 12px;color:#52656d;font-size:14px;line-height:22px;">If the button does not work, open this address in your browser:</p>
                            <p style="margin:0;word-break:break-all;color:#147d79;font-size:13px;line-height:20px;"><a href="{{link}}" style="color:#147d79;text-decoration:underline;">{{link}}</a></p>
                            <p style="margin:24px 0 0;color:#52656d;font-size:14px;line-height:22px;">If you did not request a password reset, you can safely ignore this email. Your current password will remain unchanged.</p>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:20px 32px;background-color:#f8fafb;border-top:1px solid #e1e8eb;color:#718188;font-size:12px;line-height:19px;">
                            This is an automated security message from Nexa CRM. Please do not reply to this email.
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
