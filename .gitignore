.env
.env.*
!.env.example
downloads/*.zip
downloads/*.part
*.sql.gz
*.dump
*.bak
backups/
# The complete application source is tracked. Only local runtime state is ignored.
espocrm/data/*
!espocrm/data/.data
!espocrm/data/cache/
espocrm/data/cache/*
!espocrm/data/cache/.gitkeep
!espocrm/data/logs/
espocrm/data/logs/*
!espocrm/data/logs/.gitkeep
!espocrm/data/tmp/
espocrm/data/tmp/*
!espocrm/data/tmp/.gitkeep
!espocrm/data/upload/
espocrm/data/upload/*
!espocrm/data/upload/.gitkeep
espocrm/data/config.php
espocrm/data/config-internal.php
espocrm/install/config.php

# Third-party CI fixtures and repository metadata are not runtime dependencies.
espocrm/vendor/**/.ci/
espocrm/vendor/**/.github/
espocrm/.nexa-source-version

# Local editor and operating-system files.
.idea/
.vscode/
.DS_Store
Thumbs.db

# Generated local analysis and browser-test artifacts.
.qa/
.xlsx-read/

# Generated dependency, coverage and build output.
node_modules/
test-results/
playwright-report/
coverage/
build/
dist/
