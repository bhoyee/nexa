ESPOCRM_VERSION=9.1.9
ESPOCRM_PORT=8080
ESPOCRM_SITE_URL=http://localhost:8080
ESPOCRM_TIME_ZONE=Europe/London
CRM_NAME=Nexa CRM

# Local-only fallback when SMTP is not configured. Always false outside localhost.
NEXA_SIGNUP_EXPOSE_VERIFICATION_CODE=true

# Social controls appear only when enabled and valid provider credentials are set.
NEXA_AUTH_GOOGLE_ENABLED=false
NEXA_AUTH_GOOGLE_CLIENT_ID=
NEXA_AUTH_GOOGLE_CLIENT_SECRET=
NEXA_AUTH_GOOGLE_REDIRECT_URI=
NEXA_AUTH_MICROSOFT_ENABLED=false
NEXA_AUTH_MICROSOFT_CLIENT_ID=
NEXA_AUTH_MICROSOFT_CLIENT_SECRET=
NEXA_AUTH_MICROSOFT_TENANT_ID=common
NEXA_AUTH_MICROSOFT_REDIRECT_URI=
# Base64-encoded 32-byte key used only to encrypt tenant provider secrets.
NEXA_AUTH_SECRET_KEY=replace_with_a_base64_32_byte_key

# Transactional system email. Keep credentials in the ignored .env only.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURITY=TLS
SMTP_AUTH=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Nexa CRM
PASSWORD_RECOVERY_RESEND_COOLDOWN_SECONDS=60

DB_NAME=espocrm
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=espocrm
DB_PASSWORD=replace_with_a_long_random_password
DB_ROOT_PASSWORD=replace_with_a_different_long_random_password

# Shared-schema SaaS foundation and local development identity.
CONTROL_DB_NAME=nexa_control
CONTROL_DB_USER=nexa_control
CONTROL_DB_PASSWORD=replace_with_a_third_long_random_password
LOCAL_TENANT_KEY=developer_name

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_admin_password

# Synthetic tenant accounts used only for local development.
DEMO_TENANT_A_ADMIN_USERNAME=demo-admin
DEMO_TENANT_A_ADMIN_PASSWORD=replace_with_a_tenant_a_admin_password
DEMO_TENANT_B_ADMIN_USERNAME=demo-admin-b
DEMO_TENANT_B_ADMIN_PASSWORD=replace_with_a_tenant_b_admin_password
