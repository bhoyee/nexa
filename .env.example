ESPOCRM_VERSION=9.1.9
ESPOCRM_PORT=8080
ESPOCRM_SITE_URL=http://localhost:8080
ESPOCRM_TIME_ZONE=Europe/London
CRM_NAME=Nexa CRM

DB_NAME=espocrm
DB_PASSWORD=replace_with_a_long_random_password
DB_ROOT_PASSWORD=replace_with_a_different_long_random_password

# Shared-schema SaaS foundation and local development identity.
CONTROL_DB_NAME=nexa_control
CONTROL_DB_USER=nexa_control
CONTROL_DB_PASSWORD=replace_with_a_third_long_random_password
LOCAL_TENANT_KEY=developer_name

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_admin_password

# Synthetic tenant accounts used only for local development.
DEMO_TENANT_ADMIN_USERNAME=demo-admin
DEMO_TENANT_ADMIN_PASSWORD=replace_with_a_demo_tenant_admin_password
